{
  "name": "@paulohmbrn/design",
  "version": "0.1.0",
  "description": "Base global de identidade visual e modelos de projeto para Abraço Digital.",
  "type": "module",
  "private": false,
  "preferGlobal": true,
  "bin": {
    "abraco-design": "./bin/abraco-design.mjs"
  },
  "files": [
    "bin/",
